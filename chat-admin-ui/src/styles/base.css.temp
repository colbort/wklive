/* :root {
  color: #1b1f24;
  background: #f3f5f8;
  font-family:
    Inter,
    ui-sans-serif,
    system-ui,
    -apple-system,
    BlinkMacSystemFont,
    "Segoe UI",
    sans-serif;
  font-size: 14px;
  line-height: 1.45;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
}

* {
  box-sizing: border-box;
}

html,
body,
#app {
  height: 100%;
}

body {
  margin: 0;
  min-width: 320px;
  overflow: hidden;
}

button,
input,
textarea {
  font: inherit;
}

h1,
h2,
h3,
p {
  margin: 0;
}

.merchant-shell {
  display: grid;
  grid-template-columns: 232px minmax(0, 1fr);
  height: 100vh;
  min-height: 0;
  overflow: hidden;
}

.merchant-sidebar {
  display: flex;
  flex-direction: column;
  gap: 28px;
  padding: 22px 16px;
  color: #fff;
  background: #14213d;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand-mark {
  display: grid;
  width: 40px;
  height: 40px;
  border: 0;
  place-items: center;
  border-radius: 8px;
  color: #10203a;
  background: #fca311;
  font-weight: 800;
}

.brand-button {
  pointer-events: none;
  cursor: default;
}

.drawer-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 28px;
  color: #fff;
}

.merchant-menu-drawer .brand-subtitle {
  color: #aeb8c7;
}

.merchant-menu-drawer {
  background: #14213d;
}

.merchant-menu-drawer .el-drawer__body {
  padding: 22px 16px;
  background: #14213d;
}

.merchant-menu-drawer .drawer-nav {
  display: grid;
  grid-auto-flow: row;
  grid-template-columns: 1fr;
  gap: 8px;
}

.brand-title {
  font-size: 16px;
  font-weight: 700;
}

.brand-subtitle,
.page-kicker {
  color: #788396;
  font-size: 12px;
}

.merchant-sidebar .brand-subtitle,
.agent-topbar .brand-subtitle {
  color: #aeb8c7;
}

.nav {
  display: grid;
  gap: 6px;
}

.nav-item {
  width: 100%;
  min-height: 40px;
  border: 0;
  border-radius: 6px;
  padding: 0 12px;
  color: #cdd6e3;
  background: transparent;
  text-align: left;
  cursor: pointer;
}

.nav-item:hover,
.nav-item.active {
  color: #fff;
  background: rgba(255, 255, 255, 0.12);
}

.sidebar-settings {
  margin-top: auto;
}

.sidebar-settings .el-dropdown {
  width: 100%;
}

.settings-trigger {
  display: block;
}

.merchant-main {
  display: flex;
  min-height: 0;
  min-width: 0;
  flex-direction: column;
  overflow: hidden;
  background: #f3f5f8;
}

.merchant-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 0 0 auto;
  gap: 18px;
  height: 72px;
  border-bottom: 1px solid #e6e9ef;
  padding: 0 22px;
  background: #fff;
}

.merchant-topbar h1 {
  font-size: 18px;
  font-weight: 750;
}

.merchant-content {
  flex: 1 1 auto;
  min-height: 0;
  overflow: auto;
  padding: 18px;
}

.merchant-profile,
.profile {
  display: flex;
  align-items: center;
  gap: 14px;
}

.profile-text {
  display: grid;
  justify-items: end;
}

.profile-text span {
  color: #667085;
  font-size: 12px;
}

.agent-shell {
  display: grid;
  grid-template-rows: 82px minmax(0, 1fr);
  height: 100vh;
  min-height: 0;
  overflow: hidden;
  background: #f3f5f8;
}

.agent-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
  border-bottom: 1px solid #263653;
  padding: 0 22px;
  color: #fff;
  background: #14213d;
}

.agent-content {
  min-height: 0;
  overflow: hidden;
  padding: 18px;
}

.login-page {
  display: grid;
  min-height: 100vh;
  place-items: center;
  padding: 24px;
  background:
    linear-gradient(120deg, rgba(20, 33, 61, 0.88), rgba(16, 74, 93, 0.82)),
    url("https://images.unsplash.com/photo-1556761175-b413da4baf72?auto=format&fit=crop&w=1800&q=80")
      center/cover;
}

.login-panel {
  display: grid;
  grid-template-columns: minmax(260px, 1fr) minmax(300px, 420px);
  gap: 32px;
  width: min(900px, 100%);
  padding: 36px;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24px 80px rgba(15, 23, 42, 0.26);
}

.login-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 14px;
}

.login-copy h1 {
  font-size: 34px;
}

.login-copy p {
  color: #5f6b7a;
  font-size: 16px;
}

.login-form {
  min-width: 0;
}

.full-input,
.login-button {
  width: 100%;
}

.console-page,
.workbench {
  min-height: 0;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  height: 54px;
}

.toolbar-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.search-input {
  width: clamp(120px, 18vw, 220px);
}

.table-wrap {
  flex: 1 1 auto;
  min-height: 0;
  overflow: hidden;
  border: 1px solid #e6e9ef;
  border-radius: 8px;
  background: #fff;
}

.console-page {
  display: flex;
  height: 100%;
  min-height: 0;
  flex-direction: column;
}

.workbench {
  display: grid;
  grid-template-columns: minmax(260px, 320px) minmax(480px, 1fr) minmax(280px, 340px);
  flex: 1 1 auto;
  gap: 12px;
  height: 100%;
  min-height: 0;
}

.session-panel,
.chat-panel,
.customer-panel {
  min-width: 0;
  overflow: hidden;
  border: 1px solid #e6e9ef;
  border-radius: 8px;
  background: #fff;
}

.workbench-region {
  min-height: 0;
}

.session-panel,
.customer-panel {
  padding: 14px;
}

.panel-header,
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.panel-header h2,
.chat-header h2 {
  font-size: 16px;
}

.panel-tools {
  display: flex;
  align-items: center;
  gap: 8px;
}

.session-filter {
  width: 100%;
  margin: 14px 0;
}

.session-list {
  display: grid;
  gap: 8px;
  overflow: auto;
  max-height: calc(100% - 84px);
}

.empty-state {
  display: grid;
  min-height: 88px;
  place-items: center;
  border: 1px dashed #d8dee8;
  border-radius: 8px;
  color: #667085;
  background: #f8fafc;
  font-size: 13px;
}

.session-item {
  position: relative;
  display: grid;
  gap: 5px;
  width: 100%;
  min-height: 86px;
  border: 1px solid #e7ebf0;
  border-radius: 8px;
  padding: 10px 12px;
  background: #fff;
  color: inherit;
  text-align: left;
  cursor: pointer;
}

.session-item.active {
  border-color: #409eff;
  background: #f0f7ff;
}

.session-title {
  font-weight: 700;
}

.session-meta,
.session-last {
  overflow: hidden;
  color: #6b7280;
  font-size: 12px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unread {
  position: absolute;
  top: 10px;
  right: 10px;
  display: grid;
  min-width: 20px;
  height: 20px;
  place-items: center;
  border-radius: 10px;
  padding: 0 6px;
  color: #fff;
  background: #ef4444;
  font-size: 12px;
}

.chat-panel {
  display: grid;
  grid-template-rows: 64px minmax(0, 1fr) auto;
  min-height: 0;
}

.chat-header {
  padding: 0 18px;
  border-bottom: 1px solid #e6e9ef;
}

.chat-header span {
  color: #667085;
  font-size: 12px;
}

.chat-actions {
  display: flex;
  gap: 8px;
}

.message-list {
  display: flex;
  min-height: 0;
  flex-direction: column;
  gap: 12px;
  overflow: auto;
  padding: 18px;
  background: #f8fafc;
}

.message-row {
  display: flex;
}

.message-row.mine {
  justify-content: flex-end;
}

.bubble {
  max-width: min(68%, 560px);
  border-radius: 8px;
  padding: 10px 12px;
  background: #fff;
  box-shadow: 0 1px 2px rgba(15, 23, 42, 0.06);
}

.mine .bubble {
  color: #fff;
  background: #2563eb;
}

.composer {
  border-top: 1px solid #e6e9ef;
  padding: 12px;
}

.composer-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-top: 8px;
}

.info-list {
  display: grid;
  gap: 10px;
  margin: 18px 0;
}

.info-list div {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  border-bottom: 1px solid #edf0f4;
  padding-bottom: 9px;
}

.info-list dt {
  color: #667085;
}

.info-list dd {
  margin: 0;
  font-weight: 650;
}

.note-block {
  display: grid;
  gap: 10px;
}

.note-block h3 {
  font-size: 15px;
}

@media (max-width: 1040px) {
  .merchant-shell {
    grid-template-columns: 1fr;
    grid-template-rows: 72px minmax(0, 1fr);
  }

  .merchant-sidebar {
    position: sticky;
    top: 0;
    z-index: 5;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    padding: 12px;
  }

  .brand-button {
    pointer-events: auto;
    cursor: pointer;
  }

  .merchant-sidebar > .nav {
    display: none;
  }

  .merchant-sidebar .sidebar-settings {
    margin-top: 0;
    margin-left: auto;
  }

  .merchant-main {
    min-height: 0;
  }

  .nav {
    grid-auto-flow: column;
    overflow-x: auto;
  }

  .merchant-menu-drawer .drawer-nav {
    grid-auto-flow: row;
    overflow-x: visible;
  }

  .nav-item {
    white-space: nowrap;
  }

  .workbench {
    grid-template-columns: 240px minmax(340px, 1fr);
  }

  .customer-panel {
    display: none;
  }
}

@media (max-width: 760px) {
  html,
  body,
  #app {
    width: 100%;
    max-width: 100%;
    overflow: hidden;
  }

  body {
    min-width: 0;
  }

  .merchant-shell {
    display: flex;
    width: 100%;
    height: 100dvh;
    min-height: 0;
    flex-direction: column;
    overflow: hidden;
  }

  .merchant-sidebar {
    position: relative;
    z-index: 5;
    flex: 0 0 64px;
    width: 100%;
    height: 64px;
    min-width: 0;
    gap: 10px;
    padding: 10px 12px;
    overflow: hidden;
  }

  .merchant-sidebar > .nav {
    display: none;
  }

  .merchant-sidebar .brand {
    flex: 1 1 auto;
    min-width: 0;
  }

  .merchant-sidebar .brand-mark {
    flex: 0 0 auto;
    width: 38px;
    height: 38px;
  }

  .merchant-sidebar .brand-title,
  .merchant-sidebar .brand-subtitle {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .merchant-sidebar .brand-title {
    font-size: 15px;
  }

  .merchant-sidebar .sidebar-settings {
    flex: 0 0 auto;
    margin-top: 0;
    margin-left: auto;
  }

  .merchant-sidebar .sidebar-settings .el-dropdown {
    width: auto;
  }

  .merchant-sidebar .settings-trigger {
    width: auto;
    min-height: 36px;
    padding: 0 10px;
  }

  .merchant-main {
    display: flex;
    width: 100%;
    min-width: 0;
    min-height: 0;
    flex: 1 1 auto;
    overflow: hidden;
  }

  .merchant-topbar {
    flex: 0 0 56px;
    width: 100%;
    min-width: 0;
    height: 56px;
    flex-wrap: nowrap;
    gap: 8px;
    overflow: hidden;
    padding: 0 12px;
  }

  .merchant-topbar h1 {
    overflow: hidden;
    min-width: 0;
    flex: 1 1 auto;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .merchant-profile {
    min-width: 0;
    flex: 0 1 auto;
    gap: 8px;
    margin-left: auto;
  }

  .merchant-profile .profile-text {
    min-width: 0;
  }

  .merchant-profile strong {
    display: block;
    overflow: hidden;
    max-width: 96px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .merchant-content {
    width: 100%;
    min-width: 0;
    min-height: 0;
    flex: 1 1 auto;
    overflow: auto;
    padding: 12px;
  }

  .console-page {
    height: 100%;
    min-height: 0;
  }

  .toolbar {
    height: auto;
    flex-wrap: wrap;
    gap: 8px;
  }

  .toolbar-actions {
    min-width: 0;
  }

  .toolbar-actions:first-child {
    flex: 1 1 0;
  }

  .toolbar-actions:last-child {
    flex: 0 0 auto;
  }

  .search-input {
    width: 100%;
    min-width: 0;
    max-width: 180px;
  }

  .table-wrap {
    width: 100%;
    min-width: 0;
    overflow: auto;
    -webkit-overflow-scrolling: touch;
  }

  .table-wrap .el-table {
    width: 720px;
    min-width: 720px;
  }

  .agent-shell {
    width: 100%;
    height: 100dvh;
    min-height: 0;
    overflow: hidden;
  }

  .agent-content {
    min-height: 0;
    overflow: auto;
    padding: 12px;
  }

  .agent-topbar {
    align-items: flex-start;
    flex-direction: column;
  }

  .login-panel {
    grid-template-columns: 1fr;
    padding: 24px;
  }

  .workbench {
    height: auto;
    min-height: 0;
    grid-template-columns: 1fr;
  }

  .session-panel,
  .chat-panel {
    min-height: 420px;
  }
} */
