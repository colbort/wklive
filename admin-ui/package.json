{
  "name": "admin-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write \"src/**/*.{vue,js,ts,json,css,scss}\"",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@types/cropperjs": "^1.3.3",
    "axios": "^1.7.9",
    "cropperjs": "^2.1.0",
    "element-plus": "^2.8.8",
    "pinia": "^2.2.4",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.1",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.1.4",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "prettier": "^3.1.1",
    "terser": "^5.46.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.4.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.1.10"
