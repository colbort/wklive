	RespBase
	list []OptionBill `json:"list"`
	page PageReq      `json:"page"`
}

@server (
	prefix: /admin/option
	group:  option
	jwt:    Jwt
)
service admin {
	@handler AdminCreateContract
	post /contracts (CreateContractReq) returns (CreateContractResp)

	@handler AdminUpdateContract
	post /contracts/update (UpdateContractReq) returns (OptionAdminCommonResp)

	@handler AdminGetContract
	get /contracts/detail (GetContractReq) returns (GetContractResp)

	@handler AdminListContracts
	get /contracts (ListContractsReq) returns (ListContractsResp)

	@handler AdminUpdateMarket
	post /market/update (UpdateMarketReq) returns (OptionAdminCommonResp)

	@handler AdminGetMarket
	get /market/detail (GetMarketReq) returns (GetMarketResp)

	@handler AdminListMarketSnapshots
	get /market/snapshots (ListMarketSnapshotsReq) returns (ListMarketSnapshotsResp)

	@handler AdminGetOrder
	get /orders/detail (GetOrderReq) returns (GetOrderResp)

	@handler AdminListOrders
	get /orders (ListOrdersReq) returns (ListOrdersResp)

	@handler AdminGetTrade
	get /trades/detail (GetTradeReq) returns (GetTradeResp)

	@handler AdminListTrades
	get /trades (ListTradesReq) returns (ListTradesResp)

	@handler AdminGetPosition
	get /positions/detail (GetPositionReq) returns (GetPositionResp)

	@handler AdminListPositions
	get /positions (ListPositionsReq) returns (ListPositionsResp)

	@handler AdminGetExercise
	get /exercises/detail (GetExerciseReq) returns (GetExerciseResp)

	@handler AdminListExercises
	get /exercises (ListExercisesReq) returns (ListExercisesResp)

	@handler AdminGetSettlement
	get /settlements/detail (GetSettlementReq) returns (GetSettlementResp)

	@handler AdminListSettlements
	get /settlements (ListSettlementsReq) returns (ListSettlementsResp)

	@handler AdminGetAccount
	get /accounts/detail (GetAccountReq) returns (GetAccountResp)

	@handler AdminListAccounts
	get /accounts (ListAccountsReq) returns (ListAccountsResp)

	@handler AdminGetBill
	get /bills/detail (GetBillReq) returns (GetBillResp)

	@handler AdminListBills
	get /bills (ListBillsReq) returns (ListBillsResp)
}

