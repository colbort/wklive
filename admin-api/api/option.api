type GetBillReq {
	tenantId int64  `form:"tenantId,optional"`
	id       int64  `form:"id,optional"`
	bizNo    string `form:"bizNo,optional"`
}

type GetBillResp {
	RespBase
	data OptionBill `json:"data"`
}

type ListBillsReq {
	PageReq
	tenantId        int64     `form:"tenantId,optional"`
	uid             int64     `form:"uid,optional"`
	accountId       int64     `form:"accountId,optional"`
